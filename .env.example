# Required
DISCORD_TOKEN=

# Local development
DATA_DIR=./data
COMMAND_SYNC_MODE=global

# Spawn settings
SPAWN_RATE=50
SPAWN_DESPAWN_SECONDS=240
FRESH_SPAWN_CHANCE=0.005
EVENT_FRESH_SPAWN_CHANCE=0.05
EVENT_SPAWN_DESPAWN_SECONDS=60
EVENT_MAX_SPAWNS=25
EVENT_SPAWN_DELAY_SECONDS=3

# Economy settings
CATCH_REWARD_COMMON=100
CATCH_REWARD_RARE=100
CATCH_REWARD_EPIC=100
CATCH_REWARD_LEGENDARY=100
CATCH_REWARD_EXOTIC=100
CATCH_REWARD_LIMITED_EDITION=150
CATCH_REWARD_SPECIALS=200
FRESH_CATCH_BONUS=50
SELL_VEHICLE_PRICE=100

# Render/C++ launcher
DEXBOT_PYTHON_COMMAND=python bot_runner.py
ENABLE_INSTANCE_LOCK=false
AUTO_RESTART_BOT=false

